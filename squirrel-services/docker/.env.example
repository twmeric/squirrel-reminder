# Squirrel Services Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Database Configuration
# ============================================
TIDB_HOST=localhost
TIDB_PORT=4000
TIDB_USER=root
TIDB_PASSWORD=
TIDB_DATABASE=squirrel
TIDB_DSN=root@tcp(localhost:4000)/squirrel?parseTime=true

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ============================================
# Service Endpoints
# ============================================
M03_ENDPOINT=localhost:50053
M04_ENDPOINT=localhost:8084

# ============================================
# Cloudflare Configuration
# ============================================
CLOUDFLARE_API_TOKEN=your_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_ZONE_ID=your_zone_id_here

# ============================================
# Tencent Cloud Configuration
# ============================================
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
TENCENT_REGION=ap-hongkong

# ============================================
# Application Settings
# ============================================
ENVIRONMENT=development
LOG_LEVEL=info

# Feature Flags
METRICS_ENABLED=true
TRACING_ENABLED=true
PROFILING_ENABLED=false

# Security
JWT_SECRET=change_this_in_production
API_RATE_LIMIT=1000

# ============================================
# Performance Tuning
# ============================================
# M03
M03_DB_MAX_CONNECTIONS=50
M03_DB_MAX_IDLE=10
M03_CACHE_TTL=300

# M04
M04_WORKERS=4
M04_BATCH_SIZE=100
M04_CACHE_TTL=3600
